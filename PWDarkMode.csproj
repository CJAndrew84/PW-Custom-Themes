<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net481</TargetFramework>
    <Platforms>x86</Platforms>
    <PlatformTarget>x86</PlatformTarget>
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <RootNamespace>PWDarkMode</RootNamespace>
    <AssemblyName>PWDarkMode</AssemblyName>
    <Nullable>disable</Nullable>
    <!-- PW Explorer is x86; keep everything 32-bit. -->
    <Prefer32Bit>true</Prefer32Bit>
  </PropertyGroup>

  <ItemGroup>
    <None Include="PWDarkShim.sln" />
    <None Include="PWDarkShim.vcxproj" />
  </ItemGroup>

  <!-- No compile-time Telerik references on purpose: the Telerik applier
       binds via reflection against whatever Telerik.WinControls version
       the installed PW Explorer ships, so this assembly is not pinned
       to a specific PW Update. -->

</Project>
